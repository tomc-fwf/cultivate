# ──────────────────────────────────────────────
# cultivate — environment variable reference
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ──────────────────────────────────────────────

# ── Server ──────────────────────────────────────
# HTTP port the Fastify server listens on.
# Railway overrides this automatically; only set for local dev.
# Default: 3002
PORT=3002

# Node environment. Set to "production" in Railway.
# Default: development
NODE_ENV=development

# CORS allowed origin. In production set to https://cultivate.hatstak.app.
# Default dev: http://localhost:5174
ALLOWED_ORIGIN=http://localhost:5174

# ── Auth ─────────────────────────────────────────
# REQUIRED. Secret used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must match FARMSTOCK_JWT_SECRET on the farmstock app for shared-cookie SSO.
JWT_SECRET=cultivate-dev-secret-change-in-production

# ── Database ─────────────────────────────────────
# Path to the SQLite database file.
# In production (Railway) this points to a persistent volume mount.
# Default dev: data/cultivate.db  |  Default prod (Dockerfile): /data/cultivate.db
DB_PATH=./data/cultivate.db

# ── Farmstock integration ─────────────────────────
# OPTIONAL. If set, cultivate fetches crop input catalog data (items, lots)
# from the farmstock sibling app instead of returning empty placeholders.
# Both vars must be set together or neither.
# FARMSTOCK_SERVICE_KEY must match the CULTIVATE_SERVICE_KEY env var on farmstock.
FARMSTOCK_URL=https://farmstock.hatstak.app
FARMSTOCK_SERVICE_KEY=change-me-match-farmstock-CULTIVATE_SERVICE_KEY

# ── SensorPush integration ────────────────────────
# OPTIONAL. If set, the /api/sensors/sync and /api/sensors/poll endpoints
# authenticate with SensorPush cloud and pull temperature/RH readings.
# Both vars must be set together or neither.
# These are your SensorPush account credentials (not an API key).
SENSORPUSH_EMAIL=your-sensorpush-account@example.com
SENSORPUSH_PASSWORD=your-sensorpush-password
